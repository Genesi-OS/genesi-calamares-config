#!/bin/bash
# Genesi OS - update-mirrorlist
# Refreshes BOTH /etc/pacman.d/mirrorlist (Arch) and the CachyOS mirrorlists.
# Uses reflector / rate-mirrors when available, and falls back to a curated
# static list that deliberately skips mirror.rackspace.com (has been timing
# out) and cdn-77.cachyos.org (DNS no longer resolves).

set +e

echo "==> Genesi OS: Updating mirrorlists..."

arch_ok=false

# Prefer reflector — gives the best ranked output.
if command -v reflector &> /dev/null; then
    echo "==> reflector: ranking Arch mirrors..."
    if reflector --latest 30 --protocol https --sort rate \
         --save /etc/pacman.d/mirrorlist; then
        [ -s /etc/pacman.d/mirrorlist ] && arch_ok=true
    fi
fi

# Second choice: rate-mirrors (Rust)
if ! $arch_ok && command -v rate-mirrors &> /dev/null; then
    echo "==> rate-mirrors: ranking Arch mirrors..."
    if rate-mirrors --allow-root arch > /etc/pacman.d/mirrorlist 2>/dev/null; then
        [ -s /etc/pacman.d/mirrorlist ] && arch_ok=true
    fi
fi

# Fallback: curated reliable mirrors (NO rackspace — keeps timing out).
if ! $arch_ok; then
    echo "==> Writing fallback Arch mirrorlist..."
    cat > /etc/pacman.d/mirrorlist << 'EOF'
## Arch Linux Mirrorlist - Genesi OS curated fallback
Server = https://geo.mirror.pkgbuild.com/$repo/os/$arch
Server = https://mirrors.kernel.org/archlinux/$repo/os/$arch
Server = https://mirror.osbeck.com/archlinux/$repo/os/$arch
Server = https://mirror.fcix.net/archlinux/$repo/os/$arch
Server = https://archlinux.mirror.constant.com/$repo/os/$arch
Server = https://mirrors.edge.kernel.org/archlinux/$repo/os/$arch
EOF
fi

# Always strip rackspace from whatever mirrorlist we ended up with.
sed -i '/mirror\.rackspace\.com/d' /etc/pacman.d/mirrorlist 2>/dev/null

chmod 0644 /etc/pacman.d/mirrorlist 2>/dev/null

# --- CachyOS mirrorlists ---
if command -v cachyos-rate-mirrors &> /dev/null; then
    echo "==> cachyos-rate-mirrors: ranking CachyOS mirrors..."
    cachyos-rate-mirrors || true
fi

# Refetch upstream cachyos lists too (overwrites if rate-mirrors didn't run).
for variant in cachyos-mirrorlist cachyos-v3-mirrorlist cachyos-v4-mirrorlist; do
    curl -fsSL "https://mirror.cachyos.org/$variant" \
        -o "/etc/pacman.d/$variant" 2>/dev/null || true
done

# Strip dead mirrors from cachyos lists.
for ml in /etc/pacman.d/cachyos-mirrorlist \
          /etc/pacman.d/cachyos-v3-mirrorlist \
          /etc/pacman.d/cachyos-v4-mirrorlist; do
    [ -f "$ml" ] || continue
    sed -i -e '/cdn-77\.cachyos\.org/d' \
           -e '/nl\.cachyos\.org/d' \
           -e '/mirror\.lesviallon\.fr/d' "$ml"
done

echo "==> Mirrorlists updated"
exit 0
