#!/bin/bash
# Genesi OS - create-pacman-keyring
# Initialize pacman keyring for package verification

set -e

echo "==> Genesi OS: Creating pacman keyring..."

# Start haveged if available (for entropy)
if command -v haveged &> /dev/null; then
    haveged -w 1024 &
    HAVEGED_PID=$!
    sleep 2
fi

# Initialize pacman keyring (only if not already initialized)
if [ ! -d /etc/pacman.d/gnupg ]; then
    echo "==> Initializing pacman keyring..."
    pacman-key --init
else
    echo "==> Pacman keyring already exists, skipping init..."
fi

# Kill haveged if we started it
if [ ! -z "$HAVEGED_PID" ]; then
    kill $HAVEGED_PID 2>/dev/null || true
fi

# Populate Arch Linux keys
echo "==> Populating Arch Linux keys..."
pacman-key --populate archlinux || true

# Add CachyOS key if available (for kernel packages)
if [ -f /usr/share/pacman/keyrings/cachyos.gpg ]; then
    echo "==> Adding CachyOS keys..."
    pacman-key --add /usr/share/pacman/keyrings/cachyos.gpg || true
    pacman-key --lsign-key F3B607488DB35A47 || true
    pacman-key --populate cachyos || true
fi

echo "==> Pacman keyring created successfully"
exit 0
